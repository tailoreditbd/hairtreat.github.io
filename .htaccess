# URL Rewriting
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /hairtreat/
  # Redirect any request where service-area.html is appended to another page to the correct path
  RewriteRule ^(.*)/service-area\.html$ service-area.html [R=301,L]
  # Redirect any request where image-gallery.html or images-gallery.html is appended to another page to the correct path
  RewriteRule ^(.*)/image(s)?-gallery\.html$ image-gallery.html [R=301,L]

  # Redirect direct HTML file accesses of branches to their clean URL structures
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*(uttara|uttura)\.html\s [NC]
  RewriteRule ^(uttara|uttura)\.html$ service-area.html/uttara [R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*gulshan\.html\s [NC]
  RewriteRule ^gulshan\.html$ service-area.html/gulshan [R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*dhaka\.html\s [NC]
  RewriteRule ^dhaka\.html$ service-area.html/dhaka [R=301,L]

  # Rewrite branch subpaths of service-area.html internally to their respective file
  RewriteRule ^service-area(-)?\.html/(uttara|uttura)$ uttara.html [NC,L]
  RewriteRule ^service-area(-)?\.html/gulshan$ gulshan.html [NC,L]
  RewriteRule ^service-area(-)?\.html/dhaka$ dhaka.html [NC,L]

  # Redirect direct HTML file access of Saudi Arabia NRB landing page
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*hair-loss-treatment-for-saudi-arabia-nrbs\.html\s [NC]
  RewriteRule ^hair-loss-treatment-for-saudi-arabia-nrbs\.html$ hair-loss-treatment-for-saudi-arabia-nrbs [R=301,L]

  # Rewrite clean URL internally to its file
  RewriteRule ^hair-loss-treatment-for-saudi-arabia-nrbs$ hair-loss-treatment-for-saudi-arabia-nrbs.html [NC,L]
</IfModule>

# GZip Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>
