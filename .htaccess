  RewriteCond %{THE_REQUEST} \s/([^/]+/)*service-area\.html[?\s] [NC]
  RewriteRule ^service-area\.html$ service-area [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*service-single\.html[?\s] [NC]
  RewriteRule ^service-single\.html$ service-single [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*team-single\.html[?\s] [NC]
  RewriteRule ^team-single\.html$ team-single [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*team\.html[?\s] [NC]
  RewriteRule ^team\.html$ team [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*treatments\.html[?\s] [NC]
  RewriteRule ^treatments\.html$ treatments [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*uttara\.html[?\s] [NC]
  RewriteRule ^uttara\.html$ service-area/uttara [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*video-gallery\.html[?\s] [NC]
  RewriteRule ^video-gallery\.html$ video-gallery [NC,R=301,L]

  # Rewrite clean URLs internally to static files
  RewriteRule ^about$ about.html [NC,L]
  RewriteRule ^beard-transplant$ beard-transplant.html [NC,L]
  RewriteRule ^blog-single$ blog-single.html [NC,L]
  RewriteRule ^blog$ blog.html [NC,L]
  RewriteRule ^book-appointment$ book-appointment.html [NC,L]
  RewriteRule ^case-study-single$ case-study-single.html [NC,L]
  RewriteRule ^case-study$ case-study.html [NC,L]
  RewriteRule ^codex-server-check$ codex-server-check.html [NC,L]
  RewriteRule ^contact-us$ contact-us.html [NC,L]
  RewriteRule ^contact$ contact-us [NC,R=301,L]
  RewriteRule ^dhaka$ service-area/dhaka [NC,R=301,L]
  RewriteRule ^eyebrow-transplant$ eyebrow-transplant.html [NC,L]
  RewriteRule ^faqs$ faqs.html [NC,L]
  RewriteRule ^female-hair-transplant$ female-hair-transplant.html [NC,L]
  RewriteRule ^form$ form.html [NC,L]
  RewriteRule ^fue$ fue.html [NC,L]
  RewriteRule ^fut-hair-transplant$ fut-hair-transplant.html [NC,L]
  RewriteRule ^gfc-prp$ gfc-prp.html [NC,L]
