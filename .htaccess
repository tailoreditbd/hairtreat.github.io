# URL Rewriting
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /hairtreat/

  # Redirect old branch subpaths to direct static pages so assets load correctly
  RewriteRule ^service-area(-)?\.html/(uttara|uttura)$ service-area/uttara [NC,R=301,L]
  RewriteRule ^service-area(-)?\.html/gulshan$ service-area/gulshan [NC,R=301,L]
  RewriteRule ^service-area(-)?\.html/dhaka$ service-area/dhaka [NC,R=301,L]
  RewriteRule ^(.*)/service-area\.html$ service-area [NC,R=301,L]
  RewriteRule ^(.*)/image(s)?-gallery\.html$ image-gallery [NC,R=301,L]

  # Redirect trailing slash clean URLs to no-slash clean URLs
  RewriteRule ^about/$ about [NC,R=301,L]
  RewriteRule ^beard-transplant/$ beard-transplant [NC,R=301,L]
  RewriteRule ^blog-single/$ blog-single [NC,R=301,L]
  RewriteRule ^blog/$ blog [NC,R=301,L]
  RewriteRule ^book-appointment/$ book-appointment [NC,R=301,L]
  RewriteRule ^case-study-single/$ case-study-single [NC,R=301,L]
  RewriteRule ^case-study/$ case-study [NC,R=301,L]
  RewriteRule ^codex-server-check/$ codex-server-check [NC,R=301,L]
  RewriteRule ^contact-us/$ contact-us [NC,R=301,L]
  RewriteRule ^contact/$ contact-us [NC,R=301,L]
  RewriteRule ^dhaka/?$ service-area/dhaka [NC,R=301,L]
  RewriteRule ^eyebrow-transplant/$ eyebrow-transplant [NC,R=301,L]
  RewriteRule ^faqs/$ faqs [NC,R=301,L]
  RewriteRule ^female-hair-transplant/$ female-hair-transplant [NC,R=301,L]
  RewriteRule ^form/$ form [NC,R=301,L]
  RewriteRule ^fue/$ fue [NC,R=301,L]
  RewriteRule ^fut-hair-transplant/$ fut-hair-transplant [NC,R=301,L]
  RewriteRule ^gfc-prp/$ gfc-prp [NC,R=301,L]
  RewriteRule ^gulshan/?$ service-area/gulshan [NC,R=301,L]
  RewriteRule ^hair-line-correction/$ hair-line-correction [NC,R=301,L]
  RewriteRule ^hair-loss-treatment-for-saudi-arabia-nrbs/$ hair-loss-treatment-for-saudi-arabia-nrbs [NC,R=301,L]
  RewriteRule ^hair-prp/$ hair-prp [NC,R=301,L]
  RewriteRule ^hair-transplant-technique/$ hair-transplant-technique [NC,R=301,L]
  RewriteRule ^hair-transplant-treatment/$ hair-transplant-treatment [NC,R=301,L]
  RewriteRule ^hair-transplant/$ hair-transplant [NC,R=301,L]
  RewriteRule ^hours-and-location/$ hours-and-location [NC,R=301,L]
  RewriteRule ^image-gallery/$ image-gallery [NC,R=301,L]
  RewriteRule ^index-image/$ index-image [NC,R=301,L]
  RewriteRule ^index-slider/$ index-slider [NC,R=301,L]
  RewriteRule ^index-video/$ index-video [NC,R=301,L]
  RewriteRule ^laser-hair-remover/$ laser-hair-remover [NC,R=301,L]
  RewriteRule ^laser-treatment/$ laser-treatment [NC,R=301,L]
  RewriteRule ^moustache-transplant/$ moustache-transplant [NC,R=301,L]
  RewriteRule ^p-shot/$ p-shot [NC,R=301,L]
  RewriteRule ^hair-transplant-cost/$ hair-transplant-cost [NC,R=301,L]
  RewriteRule ^reviews/$ reviews [NC,R=301,L]
  RewriteRule ^sapphire-hair-transplant/$ sapphire-hair-transplant [NC,R=301,L]
  RewriteRule ^service-area/(dhaka|gulshan|uttara)/$ service-area/$1 [NC,R=301,L]
  RewriteRule ^service-area/$ service-area [NC,R=301,L]
  RewriteRule ^service-single/$ service-single [NC,R=301,L]
  RewriteRule ^team-single/$ team-single [NC,R=301,L]
  RewriteRule ^team/$ team [NC,R=301,L]
  RewriteRule ^transplant/$ transplant [NC,R=301,L]
  RewriteRule ^treatments/$ treatments [NC,R=301,L]
  RewriteRule ^uttara/?$ service-area/uttara [NC,R=301,L]
  RewriteRule ^video-gallery/$ video-gallery [NC,R=301,L]

  # Redirect direct .html access to clean URLs
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*about\.html[?\s] [NC]
  RewriteRule ^about\.html$ about [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*beard-transplant\.html[?\s] [NC]
  RewriteRule ^beard-transplant\.html$ beard-transplant [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*blog-single\.html[?\s] [NC]
  RewriteRule ^blog-single\.html$ blog-single [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*blog\.html[?\s] [NC]
  RewriteRule ^blog\.html$ blog [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*book-appointment\.html[?\s] [NC]
  RewriteRule ^book-appointment\.html$ book-appointment [NC,R=301,L]
