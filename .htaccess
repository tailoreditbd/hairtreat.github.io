  RewriteRule ^hair-loss-treatment-for-saudi-arabia-nrbs\.html$ hair-loss-treatment-for-saudi-arabia-nrbs [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*hair-prp\.html[?\s] [NC]
  RewriteRule ^hair-prp\.html$ hair-prp [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*hair-transplant-technique\.html[?\s] [NC]
  RewriteRule ^hair-transplant-technique\.html$ hair-transplant-technique [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*hair-transplant-treatment\.html[?\s] [NC]
  RewriteRule ^hair-transplant-treatment\.html$ hair-transplant-treatment [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*hair-transplant\.html[?\s] [NC]
  RewriteRule ^hair-transplant\.html$ hair-transplant [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*transplant\.html[?\s] [NC]
  RewriteRule ^transplant\.html$ transplant [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*hours-and-location\.html[?\s] [NC]
  RewriteRule ^hours-and-location\.html$ hours-and-location [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*image-gallery\.html[?\s] [NC]
  RewriteRule ^image-gallery\.html$ image-gallery [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*index-image\.html[?\s] [NC]
  RewriteRule ^index-image\.html$ index-image [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*index-slider\.html[?\s] [NC]
  RewriteRule ^index-slider\.html$ index-slider [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*index-video\.html[?\s] [NC]
  RewriteRule ^index-video\.html$ index-video [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*index\.html[?\s] [NC]
  RewriteRule ^index\.html$ ./ [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*laser-hair-remover\.html[?\s] [NC]
  RewriteRule ^laser-hair-remover\.html$ laser-hair-remover [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*laser-treatment\.html[?\s] [NC]
  RewriteRule ^laser-treatment\.html$ laser-treatment [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*moustache-transplant\.html[?\s] [NC]
  RewriteRule ^moustache-transplant\.html$ moustache-transplant [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*p-shot\.html[?\s] [NC]
