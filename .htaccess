  RewriteRule ^case-study\.html$ case-study [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*codex-server-check\.html[?\s] [NC]
  RewriteRule ^codex-server-check\.html$ codex-server-check [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*contact-us\.html[?\s] [NC]
  RewriteRule ^contact-us\.html$ contact-us [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*contact\.html[?\s] [NC]
  RewriteRule ^contact\.html$ contact-us [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*dhaka\.html[?\s] [NC]
  RewriteRule ^dhaka\.html$ service-area/dhaka [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*eyebrow-transplant\.html[?\s] [NC]
  RewriteRule ^eyebrow-transplant\.html$ eyebrow-transplant [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*faqs\.html[?\s] [NC]
  RewriteRule ^faqs\.html$ faqs [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*female-hair-transplant\.html[?\s] [NC]
