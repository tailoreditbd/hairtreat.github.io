  RewriteCond %{THE_REQUEST} \s/([^/]+/)*form\.html[?\s] [NC]
  RewriteRule ^form\.html$ form [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*fue\.html[?\s] [NC]
  RewriteRule ^fue\.html$ fue [NC,R=301,L]
  RewriteCond %{THE_REQUEST} \s/([^/]+/)*fut-hair-transplant\.html[?\s] [NC]
  RewriteRule ^fut-hair-transplant\.html$ fut-hair-transplant [NC,R=301,L]
